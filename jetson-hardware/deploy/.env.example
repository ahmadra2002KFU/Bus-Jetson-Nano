# Copy to deploy/.env and fill in.

# Cloudflare Zero-Trust tunnel token (dashboard -> Networks -> Tunnels -> your tunnel -> Install connector).
# Route jetson.testingdomainzforprototypes.website to http://app:3232 in the tunnel's "Public Hostname" section.
CLOUDFLARE_TUNNEL_TOKEN=eyJh...replace_me...

# How long to keep events / metrics / forensic PDFs.
RETENTION_DAYS=30

# Log verbosity for the FastAPI app.
LOG_LEVEL=INFO

# Optional: a short SHA displayed in the dashboard banner and /health.
BUILD_SHA=dev

# Telegram alerter. Both vars must be set for alerts to be delivered; if
# either is empty the server logs "Telegram alerter disabled" at startup
# and the detection paths become no-ops (everything else still works).
#
# Steps to obtain these values:
#   1. Open Telegram, chat with @BotFather, send /newbot, follow prompts.
#      The bot used by this deployment is @alahsa_bus_security_bot.
#      BotFather replies once with the HTTP API token -- store it here.
#   2. Add the bot to a group (or 1:1 chat). Send any message in the chat
#      so an update exists. Then run:
#        curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#      Find chat.id in the JSON. For groups it is a negative integer.
#   3. Paste both values below and run:  docker compose up -d --build app
#
# If the token leaks, revoke it via @BotFather  ->  /revoke  and replace
# the value here, then restart the app container.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
